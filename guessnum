import random
import json
import os
from datetime import datetime

# Константы конфигурации
DEFAULT_RANGE = (1, 100)
DEFAULT_ATTEMPTS = 7
HINT_AFTER_ATTEMPTS = 5
SAVE_FILE = "game_stats.json"

def load_stats():
    """Загружает статистику игр из файла."""
    if os.path.exists(SAVE_FILE):
        with open(SAVE_FILE, 'r', encoding='utf-8') as f:
            return json.load(f)
    return {"games": []}

def save_stats(stats):
    """Сохраняет статистику игр в файл."""
    with open(SAVE_FILE, 'w', encoding='utf-8') as f:
        json.dump(stats, f, ensure_ascii=False, indent=2)

def get_difficulty_settings():
    """Позволяет пользователю выбрать уровень сложности."""
    print("\nВыберите уровень сложности:")
    print("1. Лёгкий (1–100, 10 попыток)")
    print("2. Средний (1–100, 7 попыток)")
    print("3. Сложный (1–100, 5 попыток)")
    print("4. Пользовательский (свой диапазон и количество попыток)")

    while True:
        choice = input("Ваш выбор (1–4): ")
        if choice == '1':
            return (1, 100), 10
        elif choice == '2':
            return (1, 100), 7
        elif choice == '3':
            return (1, 100), 5
        elif choice == '4':
            try:
                min_num = int(input("Минимальное число: "))
                max_num = int(input("Максимальное число: "))
                attempts = int(input("Количество попыток: "))
                if min_num >= max_num or attempts <= 0:
                    print("Некорректные значения. Попробуйте снова.")
                    continue
                return (min_num, max_num), attempts
            except ValueError:
                print("Пожалуйста, введите целые числа.")
        else:
            print("Неверный выбор. Попробуйте снова.")

def play_game():
    """Основная функция игры."""
    # Загрузка статистики
    stats = load_stats()

    # Выбор уровня сложности
    number_range, max_attempts = get_difficulty_settings()
    secret_number = random.randint(number_range[0], number_range[1])
    attempts = 0
    hint_given = False

    print(f"\nЯ загадал число от {number_range[0]} до {number_range[1]}.")
    print(f"У вас {max_attempts} попыток. Удачи!\n")

    while attempts < max_attempts:
        try:
            # Ввод числа с валидацией диапазона
            while True:
                guess_input = input(f"Попытка {attempts + 1}/{max_attempts}. Ваше число: ")
                guess = int(guess_input)

                if guess < number_range[0] or guess > number_range[1]:
                    print(f"Пожалуйста, введите число в диапазоне от {number_range[0]} до {number_range[1]}.")
                    continue
                break

            attempts += 1
            remaining = max_attempts - attempts

            # Проверка числа
            if guess < secret_number:
                print("Слишком маленькое! ")
            elif guess > secret_number:
                print("Слишком большое! ")
            else:
                print(f"🎉 Поздравляем! Вы угадали число {secret_number} за {attempts} попыток!")

                # Сохранение статистики победы
                stats["games"].append({
                    "date": datetime.now().isoformat(),
                    "result": "win",
                    "attempts": attempts,
                    "range": number_range,
                    "secret_number": secret_number
                })
                save_stats(stats)
                return True

            # Подсказка после определённого количества попыток
            if not hint_given and attempts >= HINT_AFTER_ATTEMPTS and remaining > 0:
                lower_bound = max(secret_number - 10, number_range[0])
                upper_bound = min(secret_number + 10, number_range[1])
                print(f"💡 Подсказка: число находится между {lower_bound} и {upper_bound}")
                hint_given = True

            # Уведомление об оставшихся попытках
            if remaining > 0:
                print(f"Осталось попыток: {remaining}")
            else:
                print("Попытки закончились!")

        except ValueError:
            print("Пожалуйста, введите целое число.")

    # Проигрыш
    print(f"😞 Игра окончена. Загаданное число было: {secret_number}")

    # Сохранение статистики поражения
    stats["games"].append({
        "date": datetime.now().isoformat(),
        "result": "loss",
        "attempts": max_attempts,
        "range": number_range,
        "secret_number": secret_number
    })
    save_stats(stats)
    return False

def show_stats():
    """Показывает статистику прошлых игр."""
    stats = load_stats()
    if not stats["games"]:
        print("Статистика пока пуста.")
        return

    wins = sum(1 for game in stats["games"] if game["result"] == "win")
    total = len(stats["games"])
    win_rate = (wins / total) * 100

    print(f"\n--- Статистика игр ---")
    print(f"Всего игр: {total}")
    print(f"Побед: {wins}")
    print(f"Поражений: {total - wins}")
    print(f"Процент побед: {win_rate:.1f}%")

def main():
    """Главная функция программы."""
    print("Добро пожаловать в игру 'Угадай число'!")

    while True:
        print("\n" + "="*40)
        print("1. Начать новую игру")
        print("2. Показать статистику")
        print("3. Выход")

        choice = input("Выберите действие (1–3): ")

        if choice == '1':
            play_game()
        elif choice == '2':
            show_stats()
        elif choice == '3':
            print("Спасибо за игру! До свидания!")
            break
        else:
            print("Неверный выбор. Попробуйте снова.")

if __name__ == "__main__":
    main()
